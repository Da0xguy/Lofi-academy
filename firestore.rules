rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net - deny everything by default
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Validate ID strings (prevents query/parameter injections)
    function isValidId(id) {
      return id is string && id.size() <= 128;
    }
    
    // Type and constraint validator for study user profiles
    function isValidUserProfile(data) {
      return data.username is string 
        && data.username.size() >= 1 
        && data.username.size() <= 128
        && data.avatar is string 
        && data.avatar.size() >= 1 
        && data.avatar.size() <= 32
        && (data.walletAddress == null || (data.walletAddress is string && data.walletAddress.size() <= 128))
        && (data.xp is int || data.xp is float || !('xp' in data))
        && (data.level is int || data.level is float || !('level' in data))
        && (data.completedModules is list || !('completedModules' in data))
        && (data.completedTracks is list || !('completedTracks' in data))
        && (data.claimedWelcomeXP is bool || !('claimedWelcomeXP' in data))
        && (data.mintedBadges is list || !('mintedBadges' in data))
        && (data.streak is int || data.streak is float || !('streak' in data))
        && (data.lastLoginDate is string || !('lastLoginDate' in data));
    }
    
    // Users Collection matched by lowercase wallet address
    match /users/{walletAddress} {
      // Allow single document get operations
      allow get: if isValidId(walletAddress);

      // Allow list operations to fetch leaderboard ranks
      allow list: if true;
      
      // Allow writes only if structure is perfectly safe and matches validated constraints
      allow create, update: if isValidId(walletAddress) && isValidUserProfile(request.resource.data);
    }
  }
}
